{
  "name": "howie-daily-helpers-core",
  "version": "1.0.1",
  "description": "基础工具函数 （无框架依赖，纯 TS）",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index/index.d.ts",
      "import": "./dist/index/index.js",
      "require": "./dist/index/index.cjs"
    },
    "./is": {
      "types": "./dist/is/index.d.ts",
      "import": "./dist/is/index.js",
      "require": "./dist/is/index.cjs"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "require": "./dist/logger/index.cjs"
    },
    "./eventEmitter": {
      "types": "./dist/eventEmitter/index.d.ts",
      "import": "./dist/eventEmitter/index.js",
      "require": "./dist/eventEmitter/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build:types": "tsc --build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "publish:release": "pnpm publish --access public",
    "publish:minor": "pnpm version minor && pnpm run publish",
    "publish:patch": "pnpm version patch && pnpm run publish",
    "publish:major": "pnpm version major && pnpm run publish"
  },
  "keywords": [
    "howie-daily-helpers",
    "core",
    "utils",
    "no-framework"
  ],
  "author": "howie",
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "lru-cache": "^11.5.2"
  }
}
