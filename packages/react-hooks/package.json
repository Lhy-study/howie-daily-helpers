{
  "name": "howie-daily-helpers-react-hooks",
  "version": "1.0.1",
  "description": "react hooks 集合",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build:types": "tsc --build",
